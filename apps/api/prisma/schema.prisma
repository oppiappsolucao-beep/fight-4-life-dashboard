generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  COMERCIAL
  DIRETORIA
  DESENVOLVIMENTO
  PROPRIETARIO
  PROFESSOR
}

enum CommercialStatus {
  NOVO_LEAD
  CONVERSANDO
  NAO_TEM_INTERESSE
  NAO_RESPONDE
  FECHADO
}

enum ContractStatus {
  PENDENTE
  ENVIADO
  ASSINADO
  ERRO
}

enum WorkoutPhase {
  INICIO
  MEIO
  FIM
}

enum WorkoutSource {
  OWNER
  STUDENT
}

enum ExerciseBodyRegion {
  SUPERIOR
  INFERIOR
  CARDIO
  AQUECIMENTO
  ALONGAMENTO
  GERAL
}

enum ModalityContentType {
  EXERCISE_CATALOG
  VIDEO_GALLERY
}

model Tenant {
  id         String        @id @default(uuid())
  slug       String        @unique
  name       String
  subdomain  String?       @unique
  branding   Json?
  active     Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  users      User[]
  leads      Lead[]
  students   Student[]
  config     TenantConfig?
  workouts   StudentWorkout[]
  modalities Modality[]
  lessons    ProfessorLesson[]
  attendances LessonAttendance[]
}

model Student {
  id                   String   @id @default(uuid())
  tenantId             String
  nomeCompleto         String
  cpf                  String
  rg                   String?
  dataNascimento       String
  genero               String?
  email                String
  telefone             String?
  emergenciaNome       String?
  emergenciaParentesco String?
  emergenciaTelefone   String?
  rua                  String?
  numero               String?
  cep                  String?
  cidade               String?
  planoModalidade      String
  dataInicio           String
  diaVencimento        String
  formaPagamento       String?
  fotoUrl              String?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workouts             StudentWorkout[]
  lessonAttendances    LessonAttendance[]

  @@unique([tenantId, cpf])
  @@index([tenantId, email])
  @@index([tenantId, active])
}

model TenantConfig {
  id                String  @id @default(uuid())
  tenantId          String  @unique
  zapsignToken      String?
  zapsignTemplateId String?
  zapsignBaseUrl    String? @default("https://api.zapsign.com.br")
  planosPrecos      Json?
  tenant            Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  name         String?
  role         UserRole @default(COMERCIAL)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  professorModalities ProfessorModality[]
  lessons             ProfessorLesson[]
  professorScheduleSlots ProfessorScheduleSlot[]

  @@unique([tenantId, email])
}

model Lead {
  id                  String           @id @default(uuid())
  tenantId            String
  externalId          String?
  dataCadastro        DateTime         @default(now())
  nomeCompleto        String?
  dataNascimento      String?
  cpf                 String?
  email               String?
  telefone            String?
  endereco            String?
  rua                 String?
  bairro              String?
  cep                 String?
  complemento         String?
  modalidade          String?
  redeSocial          String?
  statusComercial     CommercialStatus @default(NOVO_LEAD)
  ultimaAtualizacao   DateTime         @default(now())
  planoCliente        String?
  formaPagamento      String?
  fotoRostoUrl        String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract            Contract?

  @@index([tenantId, statusComercial])
  @@index([tenantId, telefone])
  @@index([tenantId, cpf])
}

model Contract {
  id                String         @id @default(uuid())
  leadId            String         @unique
  tokenDocumento    String?
  linkAssinatura    String?
  status            ContractStatus @default(PENDENTE)
  dataEnvio         DateTime?
  erroEnvio         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  lead              Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Exercise {
  id           String                   @id @default(uuid())
  slug         String                   @unique
  name         String
  muscleGroup  String
  equipment    String?
  instructions String
  imageUrl     String?
  gifUrl       String?
  phases       String[]
  bodyRegion   ExerciseBodyRegion       @default(GERAL)
  active       Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  workoutItems StudentWorkoutExercise[]
}

model StudentWorkout {
  id          String                   @id @default(uuid())
  tenantId    String
  studentId   String
  modalityId  String?
  title       String
  notes       String?
  workoutDate DateTime                 @default(now()) @db.Date
  source      WorkoutSource            @default(OWNER)
  active      Boolean                  @default(true)
  assignedBy  String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  tenant      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student     Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  modality    Modality?                @relation(fields: [modalityId], references: [id], onDelete: SetNull)
  exercises   StudentWorkoutExercise[]

  @@unique([studentId, workoutDate])
  @@index([tenantId, studentId])
  @@index([studentId, workoutDate])
  @@index([modalityId])
}

model ModalityScheduleSlot {
  id         String   @id @default(uuid())
  tenantId   String
  modalityId String
  weekday    Int
  startTime  String
  endTime    String
  active     Boolean  @default(true)
  modality   Modality @relation(fields: [modalityId], references: [id], onDelete: Cascade)

  @@index([tenantId, modalityId, weekday])
}

model ProfessorScheduleSlot {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  modalityId String
  weekday    Int
  startTime  String
  endTime    String
  active     Boolean  @default(true)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  modality   Modality @relation(fields: [modalityId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, modalityId, weekday])
}

model StudentWorkoutExercise {
  id               String         @id @default(uuid())
  studentWorkoutId String
  exerciseId       String
  phase            WorkoutPhase   @default(MEIO)
  order            Int
  sets             Int            @default(3)
  reps             String         @default("12")
  load             String?
  restSeconds      Int?           @default(60)
  notes            String?
  completedSets    Int[]          @default([])
  workout          StudentWorkout @relation(fields: [studentWorkoutId], references: [id], onDelete: Cascade)
  exercise         Exercise       @relation(fields: [exerciseId], references: [id])

  @@unique([studentWorkoutId, phase, order])
  @@index([studentWorkoutId, phase])
}

model ModalityTemplate {
  id          String              @id @default(uuid())
  name        String
  slug        String              @unique
  contentType ModalityContentType @default(VIDEO_GALLERY)
  description String?
  active      Boolean             @default(true)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  modalities  Modality[]
}

model Modality {
  id          String              @id @default(uuid())
  tenantId    String
  templateId  String?
  name        String
  slug        String
  contentType ModalityContentType @default(VIDEO_GALLERY)
  description String?
  linkedPlans String[]            @default([])
  active      Boolean             @default(true)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template    ModalityTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  lessons     ProfessorLesson[]
  professors  ProfessorModality[]
  scheduleSlots ModalityScheduleSlot[]
  professorScheduleSlots ProfessorScheduleSlot[]
  workouts    StudentWorkout[]

  @@unique([tenantId, slug])
  @@index([tenantId, active])
}

model ProfessorModality {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  modalityId String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  modality   Modality @relation(fields: [modalityId], references: [id], onDelete: Cascade)

  @@unique([userId, modalityId])
  @@index([tenantId, userId])
}

model ProfessorLesson {
  id           String   @id @default(uuid())
  tenantId     String
  modalityId   String
  professorId  String
  title        String
  description  String?
  classDate    DateTime @db.Date
  videoUrl     String
  thumbnailUrl String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modality     Modality @relation(fields: [modalityId], references: [id], onDelete: Cascade)
  professor    User     @relation(fields: [professorId], references: [id], onDelete: Cascade)
  attendances  LessonAttendance[]

  @@index([tenantId, modalityId, classDate])
  @@index([professorId, classDate])
}

model LessonAttendance {
  id        String          @id @default(uuid())
  tenantId  String
  lessonId  String
  studentId String
  markedAt  DateTime        @default(now())
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lesson    ProfessorLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student   Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([lessonId, studentId])
  @@index([tenantId, studentId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  COMERCIAL
  DIRETORIA
  DESENVOLVIMENTO
  PROPRIETARIO
}

enum CommercialStatus {
  NOVO_LEAD
  CONVERSANDO
  NAO_TEM_INTERESSE
  NAO_RESPONDE
  FECHADO
}

enum ContractStatus {
  PENDENTE
  ENVIADO
  ASSINADO
  ERRO
}

enum WorkoutPhase {
  INICIO
  MEIO
  FIM
}

enum WorkoutSource {
  OWNER
  STUDENT
}

enum ExerciseBodyRegion {
  SUPERIOR
  INFERIOR
  CARDIO
  AQUECIMENTO
  ALONGAMENTO
  GERAL
}

model Tenant {
  id         String        @id @default(uuid())
  slug       String        @unique
  name       String
  subdomain  String?       @unique
  branding   Json?
  active     Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  users      User[]
  leads      Lead[]
  students   Student[]
  config     TenantConfig?
  workouts   StudentWorkout[]
}

model Student {
  id                   String   @id @default(uuid())
  tenantId             String
  nomeCompleto         String
  cpf                  String
  rg                   String?
  dataNascimento       String
  genero               String?
  email                String
  telefone             String?
  emergenciaNome       String?
  emergenciaParentesco String?
  emergenciaTelefone   String?
  rua                  String?
  numero               String?
  cep                  String?
  cidade               String?
  planoModalidade      String
  dataInicio           String
  diaVencimento        String
  formaPagamento       String?
  fotoUrl              String?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workouts             StudentWorkout[]

  @@unique([tenantId, cpf])
  @@index([tenantId, email])
  @@index([tenantId, active])
}

model TenantConfig {
  id                String  @id @default(uuid())
  tenantId          String  @unique
  zapsignToken      String?
  zapsignTemplateId String?
  zapsignBaseUrl    String? @default("https://api.zapsign.com.br")
  planosPrecos      Json?
  tenant            Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  name         String?
  role         UserRole @default(COMERCIAL)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
}

model Lead {
  id                  String           @id @default(uuid())
  tenantId            String
  externalId          String?
  dataCadastro        DateTime         @default(now())
  nomeCompleto        String?
  dataNascimento      String?
  cpf                 String?
  email               String?
  telefone            String?
  endereco            String?
  rua                 String?
  bairro              String?
  cep                 String?
  complemento         String?
  modalidade          String?
  redeSocial          String?
  statusComercial     CommercialStatus @default(NOVO_LEAD)
  ultimaAtualizacao   DateTime         @default(now())
  planoCliente        String?
  formaPagamento      String?
  fotoRostoUrl        String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract            Contract?

  @@index([tenantId, statusComercial])
  @@index([tenantId, telefone])
  @@index([tenantId, cpf])
}

model Contract {
  id                String         @id @default(uuid())
  leadId            String         @unique
  tokenDocumento    String?
  linkAssinatura    String?
  status            ContractStatus @default(PENDENTE)
  dataEnvio         DateTime?
  erroEnvio         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  lead              Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Exercise {
  id           String                   @id @default(uuid())
  slug         String                   @unique
  name         String
  muscleGroup  String
  equipment    String?
  instructions String
  imageUrl     String?
  gifUrl       String?
  phases       String[]
  bodyRegion   ExerciseBodyRegion       @default(GERAL)
  active       Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  workoutItems StudentWorkoutExercise[]
}

model StudentWorkout {
  id          String                   @id @default(uuid())
  tenantId    String
  studentId   String
  title       String
  notes       String?
  workoutDate DateTime                 @default(now()) @db.Date
  source      WorkoutSource            @default(OWNER)
  active      Boolean                  @default(true)
  assignedBy  String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  tenant      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student     Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exercises   StudentWorkoutExercise[]

  @@unique([studentId, workoutDate])
  @@index([tenantId, studentId])
  @@index([studentId, workoutDate])
}

model StudentWorkoutExercise {
  id               String         @id @default(uuid())
  studentWorkoutId String
  exerciseId       String
  phase            WorkoutPhase   @default(MEIO)
  order            Int
  sets             Int            @default(3)
  reps             String         @default("12")
  load             String?
  restSeconds      Int?           @default(60)
  notes            String?
  completedSets    Int[]          @default([])
  workout          StudentWorkout @relation(fields: [studentWorkoutId], references: [id], onDelete: Cascade)
  exercise         Exercise       @relation(fields: [exerciseId], references: [id])

  @@unique([studentWorkoutId, phase, order])
  @@index([studentWorkoutId, phase])
}
